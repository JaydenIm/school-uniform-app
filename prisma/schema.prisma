// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PARTNER
  STAFF
  STUDENT
}

model Stores {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(100)   // 업체/매장명
  roadAddress    String    @db.VarChar(200)   // 도로명 주소
  detailAddress  String    @db.VarChar(100)   // 상세 주소
  phoneNumber    String?   @db.VarChar(20)    // 매장 연락처
  userId         Int       @map("user_id")
  useYn          String    @default("Y") @db.Char(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  user           Users     @relation(fields: [userId], references: [id])
  schools        Schools[]

  @@map("stores")
}

model Schools {
  id             Int       @id @default(autoincrement())
  seq            String
  schoolName     String
  yearMonth      String
  address        String?   @db.VarChar(200)   // (구) 주소 필드 - 하위 호환성 유지
  managerContact String?   @db.VarChar(50)    // (구) 담당자 연락처
  userId         Int       @map("user_id")
  storeId        Int?      @map("store_id")   // 담당 매장 ID
  useYn          String    @default("Y")
  status         String    @default("active") // active | closed
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  
  users      Users     @relation(fields: [userId], references: [id])
  store      Stores?    @relation(fields: [storeId], references: [id])
  students   Students[]

  @@map("schools")
}

model Students {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  birthDate   String?  @db.VarChar(10)
  phoneNumber String?  @db.VarChar(20)
  gender      String?  @db.VarChar(10)
  grade       String?  @db.VarChar(10)
  class       String?  @db.VarChar(10)
  token       String   @unique @default(uuid()) @db.VarChar(36) // QR 인증 토큰
  schoolId    Int
  useYn       String   @default("Y") @db.Char(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  school      Schools  @relation(fields: [schoolId], references: [id])
  measurement Measurement?

  @@index([name])
  @@map("students")
}

model Measurement {
  id           Int       @id @default(autoincrement())
  studentId    Int       @unique
  // 상의 치수 (cm)
  shoulder     Float?    // 어깨 너비
  chest        Float?    // 가슴 둘레
  upperLength  Float?    // 상의 기장
  sleeveLength Float?    // 소매 길이
  // 하의 치수 (cm)
  waist        Float?    // 허리 둘레
  hip          Float?    // 엉덩이 둘레
  thigh        Float?    // 허벅지 둘레
  pantsLength  Float?    // 바지 길이
  // 추가 품목 수량
  qtyHoodie    Int       @default(0) // 후드티
  qtyTshirt    Int       @default(0) // 반팔티
  qtyPolo      Int       @default(0) // 폴로티
  qtySweater   Int       @default(0) // 스웨터
  // 메모 및 상태
  note         String?   @db.Text
  status       String    @default("pending") // pending | measured | completed
  measuredAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  student      Students  @relation(fields: [studentId], references: [id])
  @@map("measurements")
}


model Users {
  id          Int      @id @default(autoincrement())
  loginId     String   @unique @db.VarChar(50)    // 로그인 ID
  password    String   @db.VarChar(100)           // 비밀번호 필드 추가
  name        String   @db.VarChar(50)
  phoneNumber String?  @db.VarChar(20)
  email       String   @unique @db.VarChar(100)
  image       String?  @db.LongText               // 프로필 이미지 URL 또는 Base64
  useYn       String   @default("Y") @db.Char(1)
  role        Role     @default(PARTNER)
  
  // 파트너 직원 연동 시스템
  partnerCode  String?  @unique @db.VarChar(20)    // 파트너의 고유 식별 코드
  parentUserId Int?                              // 내부 상위 관리자 (대표) ID
  staffStatus  String?  @default("pending") @db.VarChar(20) // pending | active | resigned
  parentUser   Users?   @relation("StaffRelation", fields: [parentUserId], references: [id])
  staff        Users[]  @relation("StaffRelation")

  createdAt   DateTime @default(now()) @updatedAt
  updatedAt   DateTime @default(now()) @updatedAt
  schools     Schools[]
  stores      Stores[]
  keywords    SearchKeywords[]

  @@index([name])
  @@index([phoneNumber])
  @@map("users")
}

model Sales {
  id        Int      @id @default(autoincrement())
  amount    Float
  customer  String
  email     String
  createdAt DateTime @default(now()) @updatedAt
}

model Revenue {
  id        Int      @id @default(autoincrement())
  month     String
  amount    Float
  createdAt DateTime @default(now()) @updatedAt
}

model Board {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())
}

model SearchKeywords {
  id        Int      @id @default(autoincrement())
  keyword   String   @db.VarChar(100)
  userId    Int      @map("user_id")
  useYn     String   @default("Y") @db.Char(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user      Users    @relation(fields: [userId], references: [id])

  @@map("search_keywords")
}
